# Puerto en el que corre el servidor backend (Ej: 3001)
PORT=

# Entorno de ejecución (development | production)
NODE_ENV=

# Orígenes permitidos para CORS (Ej: http://localhost:5173 o http://IP_DEL_VPS)
# En producción, usa la IP directa de tu VPS sin barra diagonal al final
ALLOWED_ORIGINS=

# Secreto de la aplicación (usado para JWT u otras encriptaciones de seguridad)
APP_SECRET=
